@model PersonalOrganizer.Models.TaskItem

@{
    ViewData["Title"] = "Редагування";
}

<div class="container mt-4">
    <h2>Редагувати завдання</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit" method="post">

                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="Title" class="form-label">Назва завдання</label>
                    <input asp-for="Title" class="form-control" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Опис</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="DueDate" class="form-label">Дедлайн</label>
                    <input asp-for="DueDate" class="form-control" type="datetime-local" />
                    <span asp-validation-for="DueDate" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Priority" class="form-label">Пріоритет</label>
                    <select asp-for="Priority" class="form-select" asp-items="Html.GetEnumSelectList<PersonalOrganizer.Models.TaskPriority>()"></select>
                    <span asp-validation-for="Priority" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Status" class="form-label">Статус</label>
                    <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<PersonalOrganizer.Models.TaskStatus>()"></select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>

                <div class="mb-3 mt-4">
                    <button type="submit" class="btn btn-warning px-4">Оновити</button>
                    <a asp-action="Index" class="btn btn-outline-secondary ms-2">Скасувати</a>
                </div>
            </form>
        </div>
    </div>
</div>