@model IEnumerable<PersonalOrganizer.Models.TaskItem>

@{
    ViewData["Title"] = "Мої завдання";
}

<h2>Мої завдання</h2>
<p>
    <a asp-action="Create" class="btn btn-primary">Створити нове завдання</a>
</p>
<form asp-action="Index" method="get" class="mb-4 mt-3 bg-light p-3 rounded shadow-sm">
    <div class="row g-2 align-items-center">

        <div class="col-md-5">
            <input type="text" name="searchString" value="@ViewBag.CurrentSearch" class="form-control" placeholder="Пошук за назвою завдання..." />
        </div>

        <div class="col-md-4">
            <select name="categoryId" class="form-select" asp-items="ViewBag.Categories">
                <option value="">-- Всі категорії --</option>
            </select>
        </div>

        <div class="col-md-3 d-flex">
            <button type="submit" class="btn btn-primary w-100 me-2">Шукати</button>
            <a asp-action="Index" class="btn btn-outline-secondary w-100">Скинути</a>
        </div>

    </div>
</form>
<table class="table table-hover">
    <thead>
        <tr>
            <th>Назва</th>
            <th>Опис</th>
            <th>Дедлайн</th>
            <th>Пріоритет</th>
            <th>Статус</th>
            <th>Категорія</th>
            <th>Дії</th>
          
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Description</td>
                <td class="@item.TimeColorClass">@item.DueDate.ToShortDateString()</td>
                <td>@item.Priority</td>
                <td>@item.Status</td>
                <td>@(item.Category?.Name ?? "Без категорії")</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Редагувати</a>
                </td>
                <td><a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger ms-1">Видалити</a></td>
            </tr>
        }
    </tbody>
   
</table>