@model PersonalOrganizer.Models.TaskItem

@{
    ViewData["Title"] = "Видалення";
}

<div class="container mt-4">
    <h2 class="text-danger">Видалити завдання?</h2>
    <hr />
    <div class="card border-danger mb-3" style="max-width: 40rem;">
        <div class="card-header bg-danger text-white">Увага! Цю дію неможливо скасувати.</div>
        <div class="card-body">
            <h5 class="card-title">@Model.Title</h5>
            <p class="card-text">@Model.Description</p>
            <p><strong>Дедлайн:</strong> @Model.DueDate.ToString("dd.MM.yyyy HH:mm")</p>

            <form asp-action="Delete" method="post" class="mt-4">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger px-4">Так, видалити</button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Скасувати</a>
            </form>
        </div>
    </div>
</div>