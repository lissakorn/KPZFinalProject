@model PersonalOrganizer.Models.TaskItem

@{
    ViewData["Title"] = "Нове завдання";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm" style="border-radius: var(--radius); overflow: hidden; border: none;">

                <div class="card-header text-white text-center py-3" style="background-color: var(--primary-pink); border-bottom: none;">
                    <h4 class="mb-0 fw-bold">✨ Створити нове завдання</h4>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create" method="post">

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Title" class="form-label fw-bold" style="color: var(--text-color);">Назва завдання <span class="text-danger">*</span></label>
                                    <input asp-for="Title" class="form-control shadow-none" placeholder="Наприклад: Підготувати звіт" />
                                    <span asp-validation-for="Title" class="text-danger mt-1 d-block small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Description" class="form-label fw-bold" style="color: var(--text-color);">Опис (необов'язково)</label>
                                    <textarea asp-for="Description" class="form-control shadow-none" rows="4" placeholder="Додаткові деталі..."></textarea>
                                    <span asp-validation-for="Description" class="text-danger mt-1 d-block small"></span>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="CategoryId" class="form-label fw-bold" style="color: var(--text-color);">Категорія</label>
                                    <select asp-for="CategoryId" class="form-select shadow-none" asp-items="ViewBag.Categories">
                                        <option value="">-- Оберіть категорію --</option>
                                    </select>
                                    <span asp-validation-for="CategoryId" class="text-danger mt-1 d-block small"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="DueDate" class="form-label fw-bold" style="color: var(--text-color);">Дедлайн <span class="text-danger">*</span></label>
                                    <input asp-for="DueDate" type="date" class="form-control shadow-none" min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                    <span asp-validation-for="DueDate" class="text-danger mt-1 d-block small"></span>
                                </div>

                                <div class="row">
                                    <div class="col-6 mb-3">
                                        <label asp-for="Priority" class="form-label fw-bold" style="color: var(--text-color);">Пріоритет</label>
                                        <select asp-for="Priority" class="form-select shadow-none" asp-items="Html.GetEnumSelectList<PersonalOrganizer.Models.TaskPriority>()">
                                            <option value="">Оберіть...</option>
                                        </select>
                                        <span asp-validation-for="Priority" class="text-danger mt-1 d-block small"></span>
                                    </div>

                                    <div class="col-6 mb-3">
                                        <label asp-for="Status" class="form-label fw-bold" style="color: var(--text-color);">Статус</label>
                                        <select asp-for="Status" class="form-select shadow-none" asp-items="Html.GetEnumSelectList<PersonalOrganizer.Models.TaskStatus>()">
                                            <option value="">Оберіть...</option>
                                        </select>
                                        <span asp-validation-for="Status" class="text-danger mt-1 d-block small"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" style="border-color: var(--soft-pink);" />

                        
                        <div class="d-flex justify-content-between align-items-center">
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                                <i class="bi bi-arrow-left"></i> Скасувати
                            </a>

                            <button type="submit" class="btn btn-primary rounded-pill px-5 shadow-sm">
                                <i class="bi bi-check-circle"></i> Зберегти
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}